# GEMINI_API_KEY: Required for Gemini AI API calls.
# This can be configured via environment variables or your deployment secrets manager.
# Configure this in your local or hosted environment.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Set this to the public URL where Attendly is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
